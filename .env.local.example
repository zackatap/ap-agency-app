# GoHighLevel OAuth (Marketplace App)
# Preferred: Use the Installation URL from GHL (avoids "Invalid client_id" at agency level)
# Get it from: Developer Marketplace > Your App > Advanced Settings > Auth > Show Install Link
GHL_INSTALLATION_URL=https://marketplace.gohighlevel.com/oauth/chooselocation?client_id=...&redirect_uri=...

# Alternative: Construct URL from Client Key (may not work for agency/whitelabel installs)
GHL_CLIENT_ID=your-client-id
GHL_CLIENT_SECRET=your-client-secret
GHL_REDIRECT_URI=https://ap-agency-app.vercel.app/api/auth/callback/ghl

# Neon Postgres (add via Vercel: Storage → Neon integration)
# Automatically injects DATABASE_URL

# Meta (Facebook) Marketing API - for ad spend on Month to Month tab
# App Secret: developers.facebook.com/apps → Your App → Settings → Basic → App Secret (click Show)
META_APP_ID=1235305674620959
META_APP_SECRET=your-app-secret
META_ACCESS_TOKEN=your-long-lived-access-token
