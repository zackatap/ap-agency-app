# GoHighLevel OAuth (Marketplace App - Single Location Only)
# Target User: Sub-Account. Custom menu URL: /v2/location/{{location.id}}/dashboard
# See docs/GHL-AUTH-SETUP.md for setup details.
GHL_CLIENT_ID=your-client-id
GHL_CLIENT_SECRET=your-client-secret
GHL_REDIRECT_URI=https://your-app.vercel.app/api/auth/callback/ghl

# Neon Postgres (add via Vercel: Storage → Neon integration)
# Automatically injects DATABASE_URL

# Timezone for attributing opportunity dates (GHL returns UTC). Default: America/Chicago
# OPPORTUNITY_TIMEZONE=America/Chicago

# Google Sheets - for Ad Account ID & Campaign Keyword lookup by location
# Paste the full service account JSON (single line or minified)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Tab gid from the sheet URL (.../edit?gid=1722936157) - defaults to 1722936157
# FACEBOOK_SHEET_GID=1722936157

# Meta (Facebook) Marketing API - for ad spend on Month to Month tab
# App Secret: developers.facebook.com/apps → Your App → Settings → Basic → App Secret (click Show)
META_APP_ID=1235305674620959
META_APP_SECRET=your-app-secret
META_ACCESS_TOKEN=your-long-lived-access-token
