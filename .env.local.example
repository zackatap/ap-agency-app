# GoHighLevel OAuth (Marketplace App)
# Target User: Sub-Account. Who can install: Agency & Sub-account. Bulk: Yes.
# Custom menu URL: /v2/location/{{location.id}}/dashboard
# See docs/GHL-AUTH-SETUP.md.
GHL_CLIENT_ID=your-client-id
GHL_CLIENT_SECRET=your-client-secret
GHL_REDIRECT_URI=https://your-app.vercel.app/api/auth/callback/ghl

# (Optional) Shared Secret from Marketplace → Advanced Settings → Auth.
# Used to decrypt iframe user context payloads.
# GHL_SHARED_SECRET=...

# (Optional) Override OAuth entry point. Default is the white-label host
# (marketplace.leadconnectorhq.com) which works for both WL and non-WL.
# Only set this if your app is a non-whitelabel public app.
# GHL_OAUTH_BASE=https://marketplace.leadconnectorhq.com/oauth/chooselocation

# (Optional, DEV ONLY) Skip webhook signature verification.
# GHL_WEBHOOK_SKIP_SIGNATURE=1

# Neon Postgres (add via Vercel: Storage → Neon integration)
# Automatically injects DATABASE_URL

# Timezone for attributing opportunity dates (GHL returns UTC). Default: America/Chicago
# OPPORTUNITY_TIMEZONE=America/Chicago

# Google Sheets - for Ad Account ID & Campaign Keyword lookup by location
# Paste the full service account JSON (single line or minified)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Tab gid from the sheet URL (.../edit?gid=1722936157) - defaults to 1722936157
# FACEBOOK_SHEET_GID=1722936157

# Google Geocoding API - used by the Client Map tab to plot client addresses.
# Strongly recommended: Nominatim (the free fallback) is throttled to 1 req/sec
# and often returns "No match" on suite-level US addresses. With a key the map
# resolves hundreds of addresses in ~10s. First 10k requests/month are free.
# Create one at https://console.cloud.google.com → enable Geocoding API →
# Credentials → Create API key → restrict to the Geocoding API.
# GOOGLE_GEOCODING_API_KEY=AIza...

# Granola content ideas → Google Sheet (used by `npm run granola:append`)
# Tab headers: #, Title, Type, Source, Status, Hooks
# Share the sheet with the service account email (Editor). GID is the tab id from the URL.
# GRANOLA_SHEET_ID=your-spreadsheet-id
# GRANOLA_SHEET_GID=0

# LLM for content idea generation (pick one — Gemini preferred if both are set)
# Get a Gemini key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...   (from https://aistudio.google.com/apikey — not Geocoding keys)
# GEMINI_MODEL=gemini-2.5-flash-lite
# Or Anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Force a provider: CONTENT_IDEAS_LLM=gemini|anthropic

# Production app URL (required for Granola OAuth redirect on Vercel)
# APP_URL=https://ap-agency-app.vercel.app

# Vercel Cron auth for Mon/Thu content-ideas job (random secret string)
# CRON_SECRET=your-random-secret

# Meta (Facebook) Marketing API - for ad spend on Month to Month tab
# App Secret: developers.facebook.com/apps → Your App → Settings → Basic → App Secret (click Show)
META_APP_ID=1235305674620959
META_APP_SECRET=your-app-secret
META_ACCESS_TOKEN=your-long-lived-access-token

# Attention Feed API - token Zapier uses to read GET /api/integrations/attention
# Generate a long random string (e.g. `openssl rand -hex 32`). Zapier sends it as
# `Authorization: Bearer <key>` or `?token=<key>`.
ATTENTION_API_KEY=your-random-secret

# Zapier Catch Hook URL for the attention workflow (ClickUp / AI paths zap).
# The in-app "Run attention workflow" button POSTs here. In Zapier, change the
# zap trigger to Webhooks → Catch Hook and paste this URL. Step 2 URL should be:
#   https://my.automatedpractice.com/api/integrations/attention?{{attentionQuery}}
# (attentionQuery comes from the hook payload: flagged=1 or flagged=1&urgency=0).
# Keep Monday schedule by adding a small schedule zap that POSTs to the same hook
# with { "scope": "flagged", "attentionQuery": "flagged=1" }.
ZAPIER_ATTENTION_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...

# MCP server - shared secret for the Gleap AI agent (Custom MCP integration).
# REQUIRED for /api/mcp/* to work (returns 503 until set). Generate a long
# random string (e.g. `openssl rand -hex 32`). Gleap sends it as
# `Authorization: Bearer <key>`. See docs/GLEAP-MCP-SETUP.md.
MCP_API_KEY=your-random-secret
